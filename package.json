{
  "name": "fastify-typeorm",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node --env-file=.env dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "typeorm": "node --env-file=.env --disable-warning=ExperimentalWarning --disable-warning=DEP0180 --loader ts-node/esm ./node_modules/typeorm/cli.js -d src/shared/infrastructure/persistence/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate src/migrations/Init",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "seed": "node --env-file=.env --disable-warning=ExperimentalWarning --disable-warning=DEP0180 --loader ts-node/esm src/seed/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "worker": "tsx watch --env-file=.env src/worker.ts",
    "worker:start": "node --env-file=.env dist/worker.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.79.3",
    "fastify": "^5.9.0",
    "fastify-type-provider-zod": "^7.0.0",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.15.43",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  }
}
